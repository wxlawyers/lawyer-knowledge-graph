# 数据库连接字符串
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lawkg

# LLM配置
LLM_API_KEY=your_deepseek_or_kimi_or_glm_api_key_here
# DeepSeek V4 Pro / Kimi K3 / GLM 5.2 均支持 OpenAI 兼容 API
# DeepSeek: https://api.deepseek.com/v1  模型名: deepseek-chat
# Kimi K3:  https://api.moonshot.cn/v1   模型名: kimi-k3
# GLM 5.2:  https://open.bigmodel.cn/api/paas/v4  模型名: glm-5.2
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 向量模型服务地址（Docker 内部自动配置为 http://vector:9998，本地运行用 http://localhost:9998）
VECTOR_API_URL=http://localhost:9998

# 法规数据API（可选）
PKULAW_API_KEY=your_pkulaw_api_key_here
YUANDIAN_API_KEY=your_yuandian_api_key_here
